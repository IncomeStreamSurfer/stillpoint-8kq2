---
const items = [
  { q: 'When does Stillpoint launch?', a: 'Early access is rolling out in waves. Waitlist members are first in line.' },
  { q: 'How much will it cost?', a: 'A small monthly or annual subscription. Early access includes a significant lifetime discount.' },
  { q: 'Is there a free tier?', a: 'Yes. The breath timer and a starter session library are free, always.' },
  { q: 'Which platforms are supported?', a: 'iOS first, Android right after. Offline downloads on both.' },
];
---

<section id="faq" class="py-24 md:py-32 bg-cream-50 border-t border-cream-300">
  <div class="max-w-3xl mx-auto px-6">
    <div class="text-xs uppercase tracking-[0.25em] text-purple-600 text-center">FAQ</div>
    <h2 class="mt-3 font-display text-4xl md:text-5xl leading-tight text-purple-900 text-center">
      Questions, gently answered.
    </h2>

    <div class="mt-12 divide-y divide-cream-300 border border-cream-300 rounded-3xl bg-cream-100">
      {items.map((item) => (
        <details class="group p-6 open:bg-cream-50">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <span class="font-display text-xl text-purple-900">{item.q}</span>
            <span class="ml-4 inline-flex h-8 w-8 items-center justify-center rounded-full border border-purple-200 text-purple-600 group-open:rotate-45 transition-transform">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M12 5v14M5 12h14" stroke-linecap="round" />
              </svg>
            </span>
          </summary>
          <p class="mt-3 text-[15px] leading-relaxed text-purple-900/70">{item.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
