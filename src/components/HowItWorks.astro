---
const steps = [
  { n: '01', title: 'Pick a moment', body: 'Three minutes. Ten. Before bed. We\'ll meet you where you are.' },
  { n: '02', title: 'Press play', body: 'A single tap. No account, no onboarding questionnaire.' },
  { n: '03', title: 'Find your stillpoint', body: 'Between the inhale and the exhale, there is a pause. That\'s the whole thing.' },
];
---

<section id="how" class="relative py-24 md:py-32">
  <div class="bloom" style="bottom:-200px;left:50%;transform:translateX(-50%);width:720px;height:480px;background:#E9DFF5;opacity:0.5;"></div>
  <div class="relative z-10 max-w-6xl mx-auto px-6">
    <div class="max-w-2xl">
      <div class="text-xs uppercase tracking-[0.25em] text-purple-600">How it works</div>
      <h2 class="mt-3 font-display text-4xl md:text-5xl leading-tight text-purple-900">Three steps. That's it.</h2>
    </div>

    <div class="mt-14 grid gap-10 md:grid-cols-3">
      {steps.map((s, i) => (
        <div class="relative">
          <div class="font-display text-6xl text-purple-200">{s.n}</div>
          <h3 class="mt-2 font-display text-2xl text-purple-900">{s.title}</h3>
          <p class="mt-2 text-[15px] leading-relaxed text-purple-900/70">{s.body}</p>
          {i < steps.length - 1 && (
            <div class="hidden md:block absolute top-8 right-0 translate-x-1/2 text-purple-300" aria-hidden="true">
              <svg width="32" height="32" viewBox="0 0 24 24" fill="none">
                <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
