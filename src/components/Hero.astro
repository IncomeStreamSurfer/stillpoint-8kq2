---
---

<section class="relative overflow-hidden">
  <!-- Bloom backdrop -->
  <div class="bloom breath" style="top:-120px;left:-120px;width:520px;height:520px;background:#D2BFEC;"></div>
  <div class="bloom breath" style="top:60px;right:-140px;width:460px;height:460px;background:#E9DFF5;animation-delay:2s;"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 pt-10 md:pt-20 pb-24 md:pb-32">
    <div class="mx-auto max-w-3xl text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-purple-200 bg-cream-50/80 backdrop-blur px-3 py-1 text-xs font-medium text-purple-700 shadow-sm">
        <span class="inline-block h-1.5 w-1.5 rounded-full bg-purple-500 breath"></span>
        Early access opening soon
      </div>

      <h1 class="mt-6 font-display text-5xl md:text-7xl leading-[1.05] tracking-tight text-purple-900">
        Find your <span class="gradient-text">stillpoint.</span>
      </h1>

      <p class="mt-6 text-lg md:text-xl leading-relaxed text-purple-900/70 max-w-2xl mx-auto">
        A quieter meditation app. Short guided sessions, breath timers and sleep stories — without the
        streaks, badges or push notifications screaming for your attention.
      </p>

      <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
        <a
          href="#waitlist"
          class="inline-flex items-center gap-2 rounded-full bg-purple-600 px-6 py-3 text-sm font-semibold text-cream-50 shadow-md hover:bg-purple-700 transition-colors"
        >
          Join the waitlist
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M5 12h14M13 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        </a>
        <a
          href="#how"
          class="inline-flex items-center gap-2 rounded-full border border-purple-200 bg-cream-50/80 backdrop-blur px-6 py-3 text-sm font-semibold text-purple-700 hover:border-purple-400 transition-colors"
        >
          How it works
        </a>
      </div>

      <div class="mt-10 flex items-center justify-center gap-6 text-xs text-purple-700/70">
        <div class="flex items-center gap-2">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-purple-400"></span>
          No ads, ever
        </div>
        <div class="flex items-center gap-2">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-purple-400"></span>
          No streaks
        </div>
        <div class="flex items-center gap-2">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-purple-400"></span>
          Offline-first
        </div>
      </div>
    </div>

    <!-- Floating phone mock -->
    <div class="mt-16 md:mt-24 flex justify-center">
      <div class="relative w-[280px] md:w-[320px] h-[560px] md:h-[640px] rounded-[48px] border border-purple-200 bg-gradient-to-b from-cream-50 to-purple-50 shadow-xl overflow-hidden">
        <div class="absolute top-3 left-1/2 -translate-x-1/2 h-6 w-24 rounded-full bg-purple-900/80"></div>
        <div class="absolute inset-x-0 top-20 flex flex-col items-center gap-4 px-6">
          <div class="text-xs uppercase tracking-[0.2em] text-purple-500">Morning</div>
          <div class="font-display text-2xl text-purple-900">Settling in</div>
          <div class="relative mt-6 h-40 w-40">
            <div class="absolute inset-0 rounded-full bg-purple-200 breath"></div>
            <div class="absolute inset-4 rounded-full bg-purple-400/70 breath" style="animation-delay:0.6s;"></div>
            <div class="absolute inset-10 rounded-full bg-purple-600 breath" style="animation-delay:1.2s;"></div>
          </div>
          <div class="mt-6 text-sm text-purple-700">Breathe in · hold · out</div>
          <div class="mt-2 text-xs text-purple-500">4 · 4 · 6</div>
        </div>
        <div class="absolute bottom-8 inset-x-0 flex justify-center">
          <div class="h-1.5 w-20 rounded-full bg-purple-900/60"></div>
        </div>
      </div>
    </div>
  </div>
</section>
